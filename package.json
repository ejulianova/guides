{
  "name": "guides",
  "version": "2.0.0",
  "description": "Simple way to highlighting DOM elements and guide your users with step-by-step welcome tours in your web app.",
  "title": "Guides.js - highlight DOM elements and make step-by-step website tours",
  "author": {
    "name": "Elena Petrova",
    "email": "elena.julianova@gmail.com"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.js"
    }
  },
  "files": [
    "dist/",
    "index.d.ts",
    "react.d.ts",
    "README.md",
    "MIGRATION.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.scss",
    "*.css"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "peerDependencies": {
    "react": ">=16.8",
    "react-dom": ">=16.8"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "babel-eslint": "^10.1.0",
    "babel-loader": "^9.1.3",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.77.2",
    "sass-loader": "^14.2.1",
    "style-loader": "^4.0.0",
    "webpack": "^5.92.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.2"
  },
  "scripts": {
    "watch": "webpack --watch",
    "start": "webpack serve --watch",
    "build": "webpack --env production",
    "build:demo": "webpack",
    "lint": "eslint src demo",
    "lint:fix": "eslint src demo --fix",
    "test": "jest",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "prepublishOnly": "npm run test && npm run build",
    "release": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "keywords": [
    "guide",
    "guides",
    "guiders",
    "guided",
    "tour",
    "welcome",
    "helper",
    "wizard",
    "highlight",
    "step-by-step",
    "intro",
    "introduction"
  ],
  "docs": "http://ejulianova.github.io/guides/",
  "demo": "http://ejulianova.github.io/guides/",
  "homepage": "http://ejulianova.github.io/guides/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ejulianova/guides.git"
  },
  "bugs": {
    "url": "https://github.com/ejulianova/guides/issues"
  },
  "license": "MIT"
}
